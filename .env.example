# Copia in cc-haha-main/.env
# Scegli il modello: phi4-mini (qualità) o qwen2.5-coder:1.5b (velocità)

ANTHROPIC_AUTH_TOKEN=sk-anything
ANTHROPIC_BASE_URL=http://localhost:4000
API_TIMEOUT_MS=3000000
DISABLE_TELEMETRY=1
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# ── Opzione A: phi4-mini — coding/ragionamento migliore, tool calling affidabile ──
ANTHROPIC_MODEL=phi4-mini
ANTHROPIC_DEFAULT_SONNET_MODEL=phi4-mini
ANTHROPIC_DEFAULT_HAIKU_MODEL=phi4-mini
ANTHROPIC_DEFAULT_OPUS_MODEL=phi4-mini

# ── Opzione B: qwen2.5-coder — più veloce, meno RAM, ottimo per task semplici ──
# ANTHROPIC_MODEL=qwen2.5-coder:1.5b
# ANTHROPIC_DEFAULT_SONNET_MODEL=qwen2.5-coder:1.5b
# ANTHROPIC_DEFAULT_HAIKU_MODEL=qwen2.5-coder:1.5b
# ANTHROPIC_DEFAULT_OPUS_MODEL=qwen2.5-coder:1.5b
