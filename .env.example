# Copy to cc-haha-main/.env
#
# cc-haha automatically picks the model based on task type:
#   HAIKU  → fast, simple tasks  (summaries, short questions)
#   SONNET → main agent          (coding, reasoning, tool use)
#   OPUS   → complex tasks       (same quality as SONNET on this hardware)

ANTHROPIC_AUTH_TOKEN=sk-anything
ANTHROPIC_BASE_URL=http://localhost:4000
API_TIMEOUT_MS=3000000
DISABLE_TELEMETRY=1
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# The proxy reads the "model" field from each request and routes to Ollama directly
ANTHROPIC_MODEL=qwen2.5-coder:1.5b
ANTHROPIC_DEFAULT_SONNET_MODEL=qwen2.5-coder:1.5b
ANTHROPIC_DEFAULT_HAIKU_MODEL=qwen2.5-coder:1.5b
ANTHROPIC_DEFAULT_OPUS_MODEL=qwen2.5-coder:1.5b
