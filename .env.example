# Copia in cc-haha-main/.env
#
# cc-haha sceglie il modello automaticamente in base al tipo di task:
#   HAIKU  → task veloci/semplici  (summarize, check, domande brevi)
#   SONNET → main agent            (coding, ragionamento, tool use)
#   OPUS   → task molto complessi  (stessa qualità di SONNET su questo hardware)

ANTHROPIC_AUTH_TOKEN=sk-anything
ANTHROPIC_BASE_URL=http://localhost:4000
API_TIMEOUT_MS=3000000
DISABLE_TELEMETRY=1
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Il proxy legge il campo "model" della richiesta e lo passa direttamente a Ollama
ANTHROPIC_MODEL=phi4-mini
ANTHROPIC_DEFAULT_SONNET_MODEL=phi4-mini
ANTHROPIC_DEFAULT_HAIKU_MODEL=qwen2.5-coder:1.5b
ANTHROPIC_DEFAULT_OPUS_MODEL=phi4-mini
